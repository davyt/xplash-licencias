rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // Admins: full read/write
    match /companies/{companyId} {
      allow read, write: if isAdmin();
    }

    match /licenses/{licenseId} {
      allow read, write: if isAdmin();
    }

    match /licenses/{licenseId}/modules/{moduleId} {
      allow read, write: if isAdmin();
    }

    // Installations: written by Cloud Function (admin SDK bypasses rules)
    match /installations/{installId} {
      allow read: if isAdmin();
      allow write: if false; // only via Cloud Function
    }

    // Events: written by Cloud Function
    match /events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // only via Cloud Function
    }

    match /adminUsers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // managed manually
    }
  }
}
